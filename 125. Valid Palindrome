class Solution:
    def isPalindrome(self, s: str) -> bool:
        s2 = ''.join(filter(str.isalnum, s)).lower()
        length = len(s2)

        left_pointer = 0
        right_pointer = length - 1

        while left_pointer < right_pointer:
            if s2[left_pointer] != s2[right_pointer]:
                return False

            left_pointer += 1
            right_pointer -= 1

        return True
