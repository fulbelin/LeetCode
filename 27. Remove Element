class Solution(object):
    def removeElement(self, nums, val):
        """
        :type nums: List[int]
        :type val: int
        :rtype: int
        """
        kept = []
        counter = 0
        length = len(nums)

        for i in range(length):
            if nums[i] != val:
                counter += 1
                kept.append(nums[i])

        nums[:] = kept

        return counter
