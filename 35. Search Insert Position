class Solution(object):
    def searchInsert(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: int
        """
        indice = len(nums)  
        for i, v in enumerate(nums):
            if v == target:
                indice = i
                break
            elif v > target:
                indice = i
                break

        return indice
        
