class Solution(object):
    def mySqrt(self, x):
        """
        :type x: int
        :rtype: int
        """
        lp = 1
        if x == 0:
            return 0
        while lp <= x:
            if lp * lp == x:
                return lp
            elif lp * lp < x:
                lp += 1
            else:
                return lp - 1
