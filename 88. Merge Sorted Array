class Solution2:
    def merge(self, nums1: List[int], m: int, nums2: List[int], n: int) -> None:
        """
        Do not return anything, modify nums1 in-place instead.
        """
        if m == 0:
            nums1[:] = nums2
            return
        if n == 0:
            return
        nums1[:] = nums1[:m] + nums2
        length = len(nums1)

        for i in range(length):
            left_pointer = 0
            right_pointer = 1

            while right_pointer < length:
                if nums1[left_pointer] > nums1[right_pointer]:
                    nums1[left_pointer], nums1[right_pointer] = nums1[right_pointer], nums1[left_pointer]

                left_pointer += 1
                right_pointer += 1

